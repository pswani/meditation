{
  "name": "meditation-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:frontend": "./scripts/dev-frontend.sh",
    "dev:backend": "./scripts/dev-backend.sh",
    "dev:all": "./scripts/dev-stack.sh",
    "build": "tsc -b && vite build",
    "build:app": "./scripts/build-local.sh",
    "start:app": "./scripts/app-start.sh",
    "stop:app": "./scripts/app-stop.sh",
    "restart:app": "./scripts/app-restart.sh",
    "status:app": "./scripts/app-status.sh",
    "logs:app": "./scripts/app-logs.sh",
    "preview": "vite preview",
    "preview:app": "./scripts/preview-local.sh",
    "media:setup": "./scripts/setup-media-root.sh",
    "media:add:custom-play": "node ./scripts/add-custom-play-media.mjs",
    "sound:add": "node ./scripts/add-sound-option.mjs",
    "db:h2:reset": "./scripts/h2-reset.sh",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^15.0.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
