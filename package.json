{
  "name": "meditation-app",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": "20.x",
    "npm": ">=10"
  },
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "build:prod": "./scripts/prod-build.sh",
    "package:prod": "./scripts/package-deploy.sh",
    "prepare:prod": "./scripts/prod-macos-setup.sh prepare-host",
    "install:prod": "./scripts/prod-macos-setup.sh install-app --bundle-dir local-data/deploy",
    "release:prod": "./scripts/prod-release.sh",
    "pipeline:verify": "./scripts/pipeline.sh verify",
    "pipeline:package": "./scripts/pipeline.sh package",
    "pipeline:release": "./scripts/pipeline.sh release",
    "start:prod": "./scripts/prod-macos-control.sh start",
    "stop:prod": "./scripts/prod-macos-control.sh stop",
    "restart:prod": "./scripts/prod-macos-control.sh restart",
    "status:prod": "./scripts/prod-macos-control.sh status",
    "logs:prod": "./scripts/prod-macos-control.sh logs --lines 120 --no-follow",
    "media:setup": "./scripts/setup-media-root.sh",
    "media:add:custom-play": "node ./scripts/add-custom-play-media.mjs",
    "sound:add": "node ./scripts/add-sound-option.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^15.0.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
