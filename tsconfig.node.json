{
  "compilerOptions": {
    "composite": true,
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "skipLibCheck": true,
    "outDir": "./local-data/tsbuild/node",
    "tsBuildInfoFile": "./local-data/tsbuild/node/tsconfig.node.tsbuildinfo"
  },
  "include": ["vite.config.ts", "eslint.config.js", "vitest.config.ts"]
}
