# Frontend API base override for pairing this app with a separate backend.
# Leave unset for the current local-first app behavior.
# Example:
# VITE_API_BASE_URL=http://192.168.1.50:8080/api

# Optional external backend workspace location.
# Example:
# MEDITATION_BACKEND_DIR=../meditation-backend

# Optional backend local-dev command.
# If unset and MEDITATION_BACKEND_DIR contains ./gradlew, helper scripts default to ./gradlew bootRun.
# Example:
# MEDITATION_BACKEND_DEV_CMD=./gradlew bootRun

# Optional backend build command.
# If unset and MEDITATION_BACKEND_DIR contains ./gradlew, helper scripts default to ./gradlew build.
# Example:
# MEDITATION_BACKEND_BUILD_CMD=./gradlew build

# Optional H2 reset location for a paired backend workflow.
# Defaults:
# MEDITATION_H2_DB_DIR=local-data/h2
# MEDITATION_H2_DB_NAME=meditation

# Optional media root override for local static custom-play files.
# Default:
# MEDITATION_MEDIA_ROOT=public/media/custom-plays
