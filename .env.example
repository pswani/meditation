# Frontend API base override for pairing this app with a separate backend.
# Leave unset to use same-origin /api requests.
# Example:
# VITE_API_BASE_URL=http://192.168.1.50:8080/api

# Optional Vite dev-proxy target when VITE_API_BASE_URL is unset.
# Use this if your backend runs on a non-default local origin during frontend dev.
# Default:
# VITE_DEV_BACKEND_ORIGIN=http://127.0.0.1:8080

# Optional backend workspace location.
# Default behavior:
# - if unset and ./backend/pom.xml exists, helper scripts use the in-repo backend module
# - otherwise the backend helpers stay configurable for a separate workspace
# Example:
# MEDITATION_BACKEND_DIR=backend

# Optional backend local-dev command.
# Defaults:
# - exec ./mvnw -Dmaven.repo.local=../local-data/m2 spring-boot:run -Dspring-boot.run.profiles=dev when the backend has a Maven wrapper
# - exec mvn -Dmaven.repo.local=../local-data/m2 spring-boot:run -Dspring-boot.run.profiles=dev when the backend has pom.xml
# - exec ./gradlew bootRun --args='--spring.profiles.active=dev' when the backend has Gradle
# Example:
# MEDITATION_BACKEND_DEV_CMD=exec mvn -Dmaven.repo.local=../local-data/m2 spring-boot:run -Dspring-boot.run.profiles=dev

# Optional backend build command.
# Defaults:
# - exec ./mvnw -Dmaven.repo.local=../local-data/m2 verify when the backend has a Maven wrapper
# - exec mvn -Dmaven.repo.local=../local-data/m2 verify when the backend has pom.xml
# - exec ./gradlew build when the backend has Gradle
# Example:
# MEDITATION_BACKEND_BUILD_CMD=exec mvn -Dmaven.repo.local=../local-data/m2 verify

# Optional managed app-stack runtime directory for PID files and logs.
# Default:
# MEDITATION_RUNTIME_DIR=local-data/runtime

# Optional frontend dev-server host and port used by:
# - npm run dev:frontend
# - npm run start:app
# Defaults:
# MEDITATION_FRONTEND_DEV_HOST=0.0.0.0
# MEDITATION_FRONTEND_DEV_PORT=5173

# Optional frontend preview host and port used by:
# - npm run preview:app
# Defaults:
# MEDITATION_FRONTEND_PREVIEW_HOST=0.0.0.0
# MEDITATION_FRONTEND_PREVIEW_PORT=4173

# Optional H2 reset location for the backend workflow.
# Defaults:
# MEDITATION_H2_DB_DIR=local-data/h2
# MEDITATION_H2_DB_NAME=meditation

# Optional backend media-storage root override.
# Default:
# MEDITATION_MEDIA_STORAGE_ROOT=local-data/media
